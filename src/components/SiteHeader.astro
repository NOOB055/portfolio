---
import ThemeToggle from './ThemeToggle.astro';

const links = [
	{ href: '/achievements', label: 'work' },
	{ href: '/blog', label: 'blog' },
	{ href: '/certifications', label: 'certs' },
];

const path = Astro.url.pathname.replace(/\/+$/, '');
const isActive = (href: string) => path === href || path.startsWith(`${href}/`);
---

<header class="sticky top-0 z-10 border-b border-line bg-surface/80 backdrop-blur">
	<div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-3">
		<a href="/" class="font-mono text-sm font-semibold tracking-tight">
			joel<span class="text-accent">.</span>thomas
		</a>
		<div class="flex items-center gap-2">
			<nav aria-label="Primary">
				<ul class="flex items-center gap-1">
					{
						links.map(({ href, label }) => (
							<li>
								<a
									href={href}
									aria-current={isActive(href) ? 'page' : undefined}
									class:list={[
										'rounded-md px-2.5 py-1.5 font-mono text-xs transition-colors',
										isActive(href)
											? 'text-accent'
											: 'text-ink-muted hover:text-ink',
									]}
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
			<ThemeToggle />
		</div>
	</div>
</header>
