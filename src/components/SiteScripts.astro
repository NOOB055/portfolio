---
/*
 * Progressive enhancements — every one is optional and degrades to nothing.
 * Bundled (served from 'self'), so no CSP hash needed. None of this is
 * required for the site to read, navigate, or submit.
 */
---

<script>
	// — Console greeting, for whoever opens DevTools —
	// A nod to minds worth standing on the shoulders of — picked at random.
	const lore = [
		'"Nothing in life is to be feared, it is only to be understood." — Marie Curie',
		'"The important thing is not to stop questioning." — Albert Einstein',
		'"The present is theirs; the future, for which I really worked, is mine." — Nikola Tesla',
		'"The most dangerous phrase in the language is: we\'ve always done it this way." — Grace Hopper',
		'"Simplicity is prerequisite for reliability." — Edsger W. Dijkstra',
		'"You must not fool yourself — and you are the easiest person to fool." — Richard Feynman',
		'"We can only see a short distance ahead, but we can see plenty there that needs to be done." — Alan Turing',
		'"An equation has no meaning for me unless it expresses a thought of God." — Srinivasa Ramanujan',
		"A distributed system is one where a computer you didn't know existed can break your own. — Leslie Lamport",
		'Grace Hopper logged the first computer "bug" in 1947 — a real moth, taped into the logbook.',
		'Hedy Lamarr co-invented frequency hopping — the idea behind Wi-Fi and Bluetooth.',
	];
	const pick = () => lore[Math.floor(Math.random() * lore.length)]!;

	console.log(
		'%c~/joel.thomas',
		'color:#34d399;font:bold 18px ui-monospace,SFMono-Regular,monospace',
	);
	console.log(
		'%cYou opened the console — of course you did.\n\n' +
			'DevSecOps engineer. I keep mission-critical deploys boring.\n' +
			'This site is static, and the footer shows the exact commit it shipped from.\n' +
			"There's a Konami code too, if you're feeling nostalgic.\n\n" +
			'github.com/NOOB055',
		'color:#9ca3af;font:13px ui-monospace,monospace;line-height:1.6',
	);
	console.log('%c' + pick(), 'color:#6b7280;font:italic 12px ui-monospace,monospace');

	const isTyping = (el: EventTarget | null) =>
		el instanceof HTMLElement &&
		(el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable);

	// — Konami code → a tasteful, on-brand toast —
	const seq = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
	let kpos = 0;
	const konami = () => {
		let el = document.getElementById('konami-toast');
		if (!el) {
			el = document.createElement('div');
			el.id = 'konami-toast';
			el.setAttribute('role', 'status');
			document.body.appendChild(el);
		}
		const toast = el;
		toast.textContent = pick(); // a fresh mind each time you enter the code
		toast.classList.add('show');
		window.clearTimeout(Number(toast.dataset.t));
		toast.dataset.t = String(window.setTimeout(() => toast.classList.remove('show'), 6500));
	};

	// — Keyboard niceties: t = toggle theme; g then h/b/w/c = navigate —
	let gPending = false;
	let gTimer = 0;
	addEventListener('keydown', (e) => {
		if (isTyping(e.target) || e.metaKey || e.ctrlKey || e.altKey) return;
		const k = e.key.length === 1 ? e.key.toLowerCase() : e.key;

		kpos = k === seq[kpos] ? kpos + 1 : k === seq[0] ? 1 : 0;
		if (kpos === seq.length) {
			kpos = 0;
			konami();
		}

		if (gPending) {
			gPending = false;
			const dest: Record<string, string> = { h: '/', b: '/blog', w: '/achievements', c: '/contact' };
			if (dest[k]) {
				e.preventDefault();
				location.href = dest[k];
				return;
			}
		}
		if (k === 'g') {
			gPending = true;
			clearTimeout(gTimer);
			gTimer = window.setTimeout(() => (gPending = false), 1000);
			return;
		}
		if (k === 't') document.getElementById('theme-toggle')?.click();
	});

	// — Subtle scroll reveal (CSS gates it on .js + no-reduced-motion) —
	const reveals = document.querySelectorAll('[data-reveal]');
	if (reveals.length && 'IntersectionObserver' in window) {
		const io = new IntersectionObserver(
			(entries) => {
				for (const en of entries) {
					if (en.isIntersecting) {
						en.target.classList.add('is-revealed');
						io.unobserve(en.target);
					}
				}
			},
			{ rootMargin: '0px 0px -10% 0px' },
		);
		reveals.forEach((r) => io.observe(r));
	}
</script>
