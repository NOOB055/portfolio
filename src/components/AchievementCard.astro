---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'achievements'>;
	/** Heading level must fit the page's outline: h2 under a page h1, h3 under a section h2. */
	headingLevel?: 'h2' | 'h3';
}

const { entry, headingLevel: Heading = 'h3' } = Astro.props;
---

<article class="rounded-xl border border-line bg-surface-raised p-6">
	<div class="flex items-baseline justify-between gap-4">
		<Heading class="text-xl font-semibold tracking-tight">
			<a
				href={`/achievements/${entry.id}`}
				class="transition-colors hover:text-accent"
			>
				{entry.data.title}
			</a>
		</Heading>
		<p class="shrink-0 font-mono text-xs text-ink-muted">{entry.data.period}</p>
	</div>
	<p class="mt-1 text-sm text-ink-muted">{entry.data.role}</p>
	<p class="mt-3 text-base">{entry.data.impact}</p>
	<ul class="mt-4 flex flex-wrap gap-2">
		{
			entry.data.stack.map((tech) => (
				<li class="rounded-full border border-line px-2.5 py-0.5 font-mono text-xs text-ink-muted">
					{tech}
				</li>
			))
		}
	</ul>
</article>
