---
import type { InferGetStaticPropsType } from 'astro';
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../utils/format';
import { getPublishedPosts } from '../../utils/collections';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props;
const { Content } = await render(post);

const words = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingMinutes = Math.max(1, Math.round(words / 200));
---

<BaseLayout
	title={`${post.data.title} — Joel Mathew Thomas`}
	description={post.data.description}
	type="article"
	ogImage={`/og/${post.id}.png`}
>
	<article class="mx-auto max-w-3xl px-6 py-12">
		<header class="mb-10">
			<p class="font-mono text-xs text-ink-muted">
				<time datetime={post.data.pubDate.toISOString()}>
					{formatDate(post.data.pubDate)}
				</time>
				<span aria-hidden="true">·</span>
				{readingMinutes} min read
			</p>
			<h1 class="mt-2 text-4xl font-bold tracking-tight text-balance">
				{post.data.title}
			</h1>
			{
				post.data.tags.length > 0 && (
					<ul class="mt-4 flex flex-wrap gap-2">
						{post.data.tags.map((tag) => (
							<li class="rounded-full border border-line px-2.5 py-0.5 font-mono text-xs text-ink-muted">
								{tag}
							</li>
						))}
					</ul>
				)
			}
		</header>
		<div class="prose">
			<Content />
		</div>
	</article>
</BaseLayout>
