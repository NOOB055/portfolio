---
import BaseLayout from '../layouts/BaseLayout.astro';
import PipelineSection from '../components/pipeline/PipelineSection.astro';
---

<BaseLayout title="Joel Thomas — DevSecOps Engineer">
	<section class="mx-auto max-w-3xl px-6 py-24">
		<p class="font-mono text-sm text-accent">~/joel.thomas</p>
		<h1 class="mt-3 text-5xl font-bold tracking-tight text-balance">
			DevSecOps engineer building paved roads to production.
		</h1>
		<p class="mt-6 max-w-xl text-lg text-ink-muted">
			Placeholder copy — I design and run GitOps platforms, multi-cluster
			Kubernetes, and the CI/CD pipelines that keep deploys boring. We will
			write the real positioning statement together in the content phase.
		</p>
	</section>
	<PipelineSection />
</BaseLayout>
