---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AchievementCard from '../../components/AchievementCard.astro';

const entries = (await getCollection('achievements')).sort(
	(a, b) => Number(b.data.featured) - Number(a.data.featured),
);
---

<BaseLayout title="Work — Joel Thomas">
	<section class="mx-auto max-w-3xl px-6 py-12">
		<h1 class="text-3xl font-bold tracking-tight">Work</h1>
		<ul class="mt-8 space-y-4">
			{
				entries.map((entry) => (
					<li>
						<AchievementCard entry={entry} />
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
