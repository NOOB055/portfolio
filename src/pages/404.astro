---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Joel Thomas" description="Page not found.">
	<section class="mx-auto max-w-3xl px-6 py-24 text-center">
		<p class="font-mono text-sm text-accent">exit code 404</p>
		<h1 class="mt-3 text-5xl font-bold tracking-tight text-balance">
			This page never converged.
		</h1>
		<p class="mx-auto mt-6 max-w-md text-lg text-ink-muted">
			Nothing in Git declares this route — so as far as production is
			concerned, it doesn't exist. That's the system working.
		</p>
		<a
			href="/"
			class="mt-8 inline-block rounded-md border border-line px-4 py-2 font-mono text-xs transition-colors hover:border-accent hover:text-accent"
		>
			→ roll back to home
		</a>
	</section>
</BaseLayout>
