---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
	title="Contact — Joel Mathew Thomas"
	description="Get in touch with Joel Mathew Thomas — DevSecOps & platform engineering."
>
	<section class="mx-auto max-w-2xl px-6 py-16">
		<p class="font-mono text-xs text-accent">contact</p>
		<h1 class="mt-1 text-3xl font-bold tracking-tight">Get in touch</h1>
		<p class="mt-3 max-w-prose text-ink-muted">
			Open to senior DevSecOps and platform engineering roles. Send a message
			below, or reach me on
			<a
				href="https://www.linkedin.com/in/joel-mathew-thomas-devsecops/"
				target="_blank"
				rel="me noopener"
				class="text-accent underline underline-offset-2">LinkedIn</a
			> and
			<a
				href="https://github.com/NOOB055"
				target="_blank"
				rel="me noopener"
				class="text-accent underline underline-offset-2">GitHub</a
			>.
		</p>
		<ContactForm />
	</section>
</BaseLayout>
