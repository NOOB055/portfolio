{
	"ci": {
		"collect": {
			"staticDistDir": "./dist",
			"numberOfRuns": 3,
			"url": [
				"http://localhost/",
				"http://localhost/blog/",
				"http://localhost/blog/why-deploys-should-be-boring/",
				"http://localhost/achievements/",
				"http://localhost/certifications/"
			]
		},
		"assert": {
			"//": "3 runs, median-aggregated. Hard gates on the deterministic dimensions (a11y/seo/best-practices/CLS); CPU-timing metrics get runner-realistic headroom because gating tight on a shared CI runner produces false failures.",
			"assertions": {
				"categories:performance": ["error", { "minScore": 0.85 }],
				"categories:accessibility": ["error", { "minScore": 0.95 }],
				"categories:best-practices": ["error", { "minScore": 0.95 }],
				"categories:seo": ["error", { "minScore": 0.95 }],
				"cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
				"largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }]
			}
		},
		"upload": { "target": "temporary-public-storage" }
	}
}
